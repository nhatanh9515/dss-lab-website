# ==========================================================================
#  DSS HOMELAB — Biến môi trường
#  Copy file này thành ".env" rồi điền giá trị thật. KHÔNG commit file .env.
# ==========================================================================

# --- Database Postgres (Neon) ---------------------------------------------
# Lấy ở Neon > Project > Connection string. Dùng ?sslmode=verify-full ở cuối
# (bảo mật đầy đủ, và tránh cảnh báo deprecation của thư viện pg).
DATABASE_URI=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=verify-full

# --- Payload ---------------------------------------------------------------
# Chuỗi bí mật để mã hoá phiên đăng nhập. Đã sinh sẵn 1 chuỗi ngẫu nhiên bên dưới,
# bạn có thể giữ nguyên hoặc thay bằng chuỗi khác.
PAYLOAD_SECRET=CHANGE_ME_RANDOM_SECRET

# URL gốc của site (dùng cho link trong email, preview...). Khi chạy máy để nguyên.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Google Analytics 4 (tuỳ chọn) ----------------------------------------
# Mã đo lường GA4 dạng G-XXXXXXXXXX. Để trống thì web vẫn chạy, chỉ là không đo.
# Lấy ở: analytics.google.com > Admin > Data Streams > chọn luồng web > Measurement ID.
NEXT_PUBLIC_GA4_ID=

# --- Meta (Facebook) Pixel (tuỳ chọn) -------------------------------------
# Mã Pixel dạng chuỗi số. Để trống thì bỏ qua.
# Lấy ở: business.facebook.com > Events Manager > Data Sources > chọn Pixel > ID.
NEXT_PUBLIC_META_PIXEL_ID=

# --- Cloudflare R2 (lưu ảnh) ----------------------------------------------
# Tên bucket đã tạo (vd: dss-homelab-media)
R2_BUCKET=dss-homelab-media
# Endpoint dạng https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# Khoá API R2 (Object Read & Write)
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# URL công khai để khách xem ảnh (R2.dev subdomain), vd: https://pub-xxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev
